# ==========================================
# AccomPartner Backend Environment Variables
# ==========================================
# 這是您的環境變數「範本檔」。
# 當您部署到新環境或是新成員加入專案時，
# 請將此檔案複製一份並改名為 `.env`，
# 然後填入符合該機器真實情況的路徑與參數。

# ── 模型與資源路徑 ─────────────────────
# 模型目錄（存放 .pt 檔和 token 辭庫）
# 預設路徑： backend/app/resources/
MODEL_DIR=C:/path/to/your/model/directory

# ── API 效能與限制 ─────────────────────
# Rate Limiting（每 IP 每分鐘最多幾次 API 呼叫）
RATE_LIMIT=10

# ── 音樂生成預設值 ─────────────────────
# 伺服器 BPM 預設值（前端未指定時使用）
DEFAULT_BPM=120

# ── 網路安全 (CORS) ────────────────────
# CORS 允許的前端來源
# (在地端開發填寫 localhost, 在雲端則可填寫您的 IP 或網址)
# 如果允許多個來源，請用逗號隔開 (不可有空白)，或者直接設定為 * 允許所有連線。
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
